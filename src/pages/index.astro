---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/home.css";

type SlideFM = { image: string; alt?: string };
type SlideVM = { src: string; alt: string };

type FeaturedSectionFM = {
  image?: string;
  title?: string;
  text?: string;
};

type HomeCardFM = {
  title?: string;
  image?: string;
  text?: string;
  buttonText?: string;
  buttonLink?: string;
};

const homeEntries = await Astro.glob("../content/home/home.md");
const home = homeEntries[0];

const slides: SlideVM[] = (home?.frontmatter?.slides ?? []).map((s: SlideFM) => ({
  src: s.image,
  alt: s.alt ?? "",
}));

const featuredSection: FeaturedSectionFM | undefined = home?.frontmatter?.featuredSection;
const homeCards: HomeCardFM[] = home?.frontmatter?.homeCards ?? [];
---

<BaseLayout title="LETS">
  <section class="home-slider" aria-label="Home slider" data-slider>
    <div class="home-slider-viewport" data-viewport>
      <div class="home-slider-track" data-track>
        {slides.length > 0 ? (
          slides.map((s: SlideVM, idx: number) => (
            <figure class="home-slide">
              <img src={s.src} alt={s.alt} loading={idx === 0 ? "eager" : "lazy"} />
            </figure>
          ))
        ) : (
          <figure class="home-slide">
            <div style="padding: 40px; text-align:center; color: rgba(0,0,0,.6);">
              No slides yet. Add slides in <b>/admin</b> → Home.
            </div>
          </figure>
        )}
      </div>

      {slides.length > 1 && (
        <>
          <button class="slider-btn slider-btn--prev" type="button" aria-label="Previous slide" data-prev>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M15.5 19 8.5 12l7-7"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>

          <button class="slider-btn slider-btn--next" type="button" aria-label="Next slide" data-next>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M8.5 5 15.5 12l-7 7"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
        </>
      )}
    </div>

    {slides.length > 1 && (
      <div class="home-slider-dots" aria-hidden="true" data-dots>
        {slides.map((_: SlideVM, i: number) => (
          <span class={`dot ${i === 0 ? "is-active" : ""}`}></span>
        ))}
      </div>
    )}

    <div class="home-slider-rule" aria-hidden="true"></div>
  </section>

  <section class="home-about" aria-label="Featured home section">
    <div class="home-about-item">
      <div class="home-about-inner">
        <div class="home-about-media">
          <img
            class="home-about-image"
            src={featuredSection?.image ?? "/images/home/wordcloud.png"}
            alt={featuredSection?.title ?? "Section image"}
            loading="lazy"
          />
        </div>

        <div class="home-about-content">
          <h2 class="home-about-title">{featuredSection?.title ?? "About..."}</h2>
          <p class="home-about-text">
            {featuredSection?.text ?? "No featured section yet. Add content in /admin → Home."}
          </p>
        </div>
      </div>
    </div>
  </section>

  {homeCards.length > 0 && (
    <section class="home-cards" aria-label="Home cards">
      <div class="home-cards-grid">
        {homeCards.map((card: HomeCardFM) => (
          <article class="home-card">
            {card.image && (
              <div class="home-card-media">
                <img
                  class="home-card-image"
                  src={card.image}
                  alt={card.title ?? "Card image"}
                  loading="lazy"
                />
              </div>
            )}

            <div class="home-card-body">
              <h3 class="home-card-title">{card.title ?? ""}</h3>

              {card.text && <p class="home-card-text">{card.text}</p>}

              {card.buttonText && card.buttonLink && (
                <a
                  class="home-card-button"
                  href={card.buttonLink}
                  target={card.buttonLink.startsWith("http") ? "_blank" : undefined}
                  rel={card.buttonLink.startsWith("http") ? "noreferrer" : undefined}
                >
                  {card.buttonText}
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-slider]");
    if (!root) return;

    const track = root.querySelector("[data-track]");
    const slideEls = Array.from(root.querySelectorAll(".home-slide"));
    const prevBtn = root.querySelector("[data-prev]");
    const nextBtn = root.querySelector("[data-next]");

    const dotsWrap = root.querySelector("[data-dots]");
    const dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll(".dot")) : [];

    if (!track || slideEls.length <= 1 || !prevBtn || !nextBtn) return;

    let idx = 0;

    const setIndex = (next) => {
      idx = (next + slideEls.length) % slideEls.length;
      track.style.transform = `translateX(-${idx * 100}%)`;

      if (dots.length) {
        dots.forEach((d, i) => d.classList.toggle("is-active", i === idx));
      }
    };

    prevBtn.addEventListener("click", () => setIndex(idx - 1));
    nextBtn.addEventListener("click", () => setIndex(idx + 1));

    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") setIndex(idx - 1);
      if (e.key === "ArrowRight") setIndex(idx + 1);
    });

    root.tabIndex = 0;

    setIndex(0);
    if (window.__homeSliderTimer) clearInterval(window.__homeSliderTimer);
    window.__homeSliderTimer = setInterval(() => setIndex(idx + 1), 5000);
  })();
</script>